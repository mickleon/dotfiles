{
    "cpu": {
        "interval": 5,
        "format": "ï’¼  {usage}%",
        "tooltip-format": "CPU: {usage}%\nLoad: {load}"
    },
    "memory": {
        "interval": 5,
        "format": "î؟…   {percentage}%",
        "tooltip-format": "Memory: {used:0.1f}G / {total:0.1f}G ({percentage}%)\nSwap: {swapUsed:0.1f}G / {swapTotal:0.1f}G"
    },
    "disk": {
        "interval": 30,
        "format": "َ°‹ٹ  {percentage_used}%",
        "format-warning": "َ°‹ٹ  {percentage_used}%",
        "format-critical": "َ°‹ٹ  {percentage_used}%",
        "path": "/",
        "tooltip-format": "Disk: {used} / {total} ({percentage_used}%)",
        "states": {
            "warning": 80,
            "critical": 90
        }
    },
    "network": {
        "format-icons": [
            "َ°¤¯",
            "َ°¤ں",
            "َ°¤¢",
            "َ°¤¥",
            "َ°¤¨"
        ],
        "format": "{icon}",
        "format-wifi": "{icon}",
        "format-ethernet": "{ifname} َ°€‚",
        "format-disconnected": "َ°¤®",
        "tooltip-format-wifi": "{essid} ({signalStrength}%)\nIP: {ipaddr}\nâ‡£{bandwidthDownBytes}  â‡،{bandwidthUpBytes}",
        "tooltip-format-ethernet": "IP: {ipaddr}\nâ‡£{bandwidthDownBytes}  â‡،{bandwidthUpBytes}",
        "tooltip-format-disconnected": "Disconnected",
        "interval": 3,
        "nospacing": 1,
        "on-click": "nm-connection-editor"
    },
    "battery": {
        "format": "{icon}  {capacity}%",
        "format-charging": "{icon}  {capacity}%",
        "format-plugged": "{icon}  {capacity}%",
        "format-alt": "{icon}  {time}",
        "format-icons": {
            "charging": [
                "َ°¢œ",
                "َ°‚†",
                "َ°‚‡",
                "َ°‚ˆ",
                "َ°¢‌",
                "َ°‚‰",
                "َ°¢‍",
                "َ°‚ٹ",
                "َ°‚‹",
                "َ°‚…"
            ],
            "default": [
                "َ°پ؛",
                "َ°پ»",
                "َ°پ¼",
                "َ°پ½",
                "َ°پ¾",
                "َ°پ؟",
                "َ°‚€",
                "َ°‚پ",
                "َ°‚‚",
                "َ°پ¹"
            ]
        },
        "format-full": "100% َ°‚…",
        "tooltip-format-discharging": "{power:>1.0f}Wâ†“ {capacity}%\nTime remaining: {time}",
        "tooltip-format-charging": "{power:>1.0f}Wâ†‘ {capacity}%\nTime until full: {time}",
        "tooltip-format-full": "Full ({capacity}%)",
        "on-click-right": "powerprofilesctl",
        "interval": 5,
        "states": {
            "warning": 20,
            "critical": 10
        }
    },
    "bluetooth": {
        "format": "ïٹ”",
        "format-disabled": "َ°‚²",
        "format-connected": "َ°‚± ",
        "tooltip-format": "Devices connected: {num_connections}",
        "on-click": "blueman-manager"
    },
    "power-profiles-daemon": {
        "format": "{icon}",
        "tooltip-format": "Power profile: {profile}\nDriver: {driver}",
        "tooltip": true,
        "format-icons": {
            "default": "ïƒ§",
            "performance": "ïƒ§",
            "balanced": "ï‰ژ",
            "power-saver": "ïپ¬"
        }
    },
    "pulseaudio": {
        "scroll-step": 0, // %, can be a float
        "format": "{icon}   {volume}%  {format_source}",
        "format-bluetooth": "{icon} ïٹ”   {volume}%  {format_source}",
        "format-bluetooth-muted": "{icon} ïٹ” î»¨    {volume}%  {format_source}",
        "format-muted": "î»¨   {volume}%  {format_source}",
        "format-source": "ï„° {volume}%",
        "format-source-muted": "ï„±",
        "format-icons": {
            "headphone": "ï€¥",
            "hands-free": "َ°‹ژ",
            "headset": "َ°‹ژ",
            "phone": "ï‚•",
            "portable": "ï‚•",
            "car": "ï†¹",
            "default": [
                "ï€¦",
                "ï€§",
                "ï€¨"
            ]
        },
        "on-click": "pavucontrol"
    },
    "tray": {
        "icon-size": 12,
        "spacing": 12
    },
    "mpris": {
        "format": "{status_icon}  {artist} â€” {title}",
        "format-paused": "{status_icon}  {artist} â€” {title}",
        "format-stopped": "{status_icon}",
        "format-disconnected": "",
        "status-icons": {
            "paused": "ïپŒ",
            "playing": "ïپ‹",
            "stopped": "âڈ¹"
        },
        "tooltip-format": "{album}\n{position} / {length}",
        "on-click": "playerctl play-pause",
        "max-length": 75
    },
    "mpd": {
        "format": "{stateIcon}  {consumeIcon}{randomIcon}{repeatIcon}{singleIcon}{artist} â€” {title}",
        "format-disconnected": "",
        "format-stopped": "",
        "unknown-tag": "N/A",
        "interval": 5,
        "consume-icons": {
            "on": "َ°©؛ "
        },
        "random-icons": {
            "off": "",
            "on": "ïپ´ "
        },
        "repeat-icons": {
            "on": "َ°‘– "
        },
        "single-icons": {
            "on": "َ°‘ک "
        },
        "state-icons": {
            "paused": "ïپŒ",
            "playing": "ïپ‹"
        },
        "tooltip-format": "{album}\n{elapsedTime:%M:%S} / {totalTime:%M:%S}\n{songPosition}/{queueLength}  {volume}%",
        "tooltip-format-disconnected": "MPD (disconnected)",
        "on-click": "rmpc togglepause",
        "server": "/tmp/mpd_socket",
        "port": 6600
    },
    "temperature": {
        "thermal-zone": 2,
        "hwmon-path": "/sys/class/hwmon/hwmon3/temp2_input",
        "format": "{temperatureC}آ°C ï‹‰",
        "critical-threshold": 70,
        "format-critical": "ï‹‡ {temperatureC}آ°C",
        "format-icons": [
            "ï‹‹", // Icon: temperature-empty
            "ï‹ٹ", // Icon: temperature-quarter
            "ï‹‰", // Icon: temperature-half
            "ï‹ˆ", // Icon: temperature-three-quarters
            "ï‹ˆ" // Icon: temperature-full
        ],
        "tooltip-format": "Temperature: {temperatureC}آ°C",
        "on-click": "omarchy-launch-or-focus-tui btop",
        "interval": 5
    },
    "idle_inhibitor": {
        "format": "{icon}",
        "format-icons": {
            "activated": "َ°’³",
            "deactivated": "َ°’²"
        },
        "tooltip-format": "{status}",
        "tooltip-format-activated": "Idle inhibitor: Active",
        "tooltip-format-deactivated": "Idle inhibitor: Inactive",
        "on-click": "toggle"
    },
    "clock": {
        "locale": "ru_RU.UTF-8",
        "format": "{:L%d %B %R}",
        "format-alt": "{:L%d %B %R}",
        "tooltip-format": "<tt><small>{calendar}</small></tt>",
        "calendar": {
            "mode": "month",
            "mode-mon-col": 3,
            "weeks-pos": "left",
            "on-scroll": 1,
            "on-click-right": "mode",
            "format": {
                "months": "<span color='#cad3f5'><b>{}</b></span>",
                "days": "<span color='#cad3f5'><b>{}</b></span>",
                "weeks": "<span color='#8aadf4'><b>W{}</b></span>",
                "weekdays": "<span color='#cad3f5'><b>{}</b></span>",
                "today": "<span color='#8aadf4'><b><u>{}</u></b></span>"
            }
        },
        "actions": {
            "on-click-right": "mode",
            "on-scroll-up": "shift_up",
            "on-scroll-down": "shift_down"
        }
    },
    "privacy": {
        "icon-size": 12
    },
    "group/system": {
        "orientation": "horizontal",
        "modules": [
            "privacy",
            "pulseaudio",
            "bluetooth",
            "network",
            "battery"
        ]
    },
    "group/langtime": {
        "orientation": "horizontal",
        "modules": [
            "hyprland/language",
            "clock"
        ]
    },
    "group/hardware": {
        "orientation": "horizontal",
        "modules": [
            "cpu",
            "memory",
            "disk"
        ]
    }
}
