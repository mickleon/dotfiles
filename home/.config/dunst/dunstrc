[global]
height = (50, 300)
offset = (10, 20)
font = Adwaita Sans 9
corner_radius = 12
frame_color = "#8aadf4"
frame_width = 2
separator_color= frame
highlight = "#8aadf4"

[urgency_low]
background = "#24273abf"
foreground = "#cad3f5"

[urgency_normal]
background = "#24273abf"
foreground = "#cad3f5"

[urgency_critical]
background = "#24273abf"
foreground = "#cad3f5"
frame_color = "#f5a97f"
